# ClimateInsight 环境变量模板 — 复制为 .env 后填入真实值
# 所有密码必须替换！不要提交真实 .env 到 Git

MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_DATABASE=climate_dw
MYSQL_USER=climate_app
MYSQL_PASSWORD=change-me
MYSQL_ROOT_PASSWORD=change-root-password

HIVE_CONTAINER=hive-server
HIVE_JDBC_URL=jdbc:hive2://hive-server:10000

API_PORT=5000
FLASK_DEBUG=false
CORS_ORIGINS=http://localhost:8080,http://localhost:5173

# Agent — LLM驱动意图识别 (DeepSeek)
AGENT_ENABLED=true
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_API_KEY=sk-your-key-here
LLM_MODEL=deepseek-chat
