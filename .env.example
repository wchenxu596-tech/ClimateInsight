# ============================================================
# ClimateInsight 环境变量 — 复制为 .env 后按需修改
# cp .env.example .env
# ============================================================

# ─── MySQL ───
# 自包含模式（默认）：内置 MySQL，密码统一
# 集群模式：连接外部 Hadoop 集群的 tier4_stu_mysql
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_DATABASE=climate_dw
MYSQL_USER=climate_app
MYSQL_PASSWORD=climate123
MYSQL_ROOT_PASSWORD=climate123

# ─── 端口 ───
API_PORT=5000
FRONTEND_PORT=8080
MYSQL_PORT=3307          # 内置 MySQL 对外端口（避免与本机冲突）

# ─── Flask ───
FLASK_DEBUG=false
CORS_ORIGINS=http://localhost:8080,http://localhost:5173

# ─── AI Agent（可选，留空则纯规则引擎） ───
AGENT_ENABLED=false
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=
