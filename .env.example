# ============================================================
# ClimateInsight 环境变量 — 复制为 .env 后修改
# ============================================================

# ─── MySQL（外部集群 tier4_stu_mysql） ───
MYSQL_HOST=tier4_stu_mysql
MYSQL_PORT=3306
MYSQL_DATABASE=climate_dw
MYSQL_USER=root
MYSQL_PASSWORD=123456

# ─── 端口 ───
API_PORT=5000
FRONTEND_PORT=8080

# ─── Flask ───
FLASK_DEBUG=false
CORS_ORIGINS=http://localhost:8080,http://localhost:5173

# ─── AI Agent（可选，留空则用规则引擎） ───
AGENT_ENABLED=false
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=
