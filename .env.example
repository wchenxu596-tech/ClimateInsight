# ClimateInsight 环境变量模板 — 复制为 .env 后填入真实值
# 所有密码必须替换！不要提交真实 .env 到 Git

MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_DATABASE=climate_dw
MYSQL_USER=root
MYSQL_PASSWORD=change-me
MYSQL_ROOT_PASSWORD=change-root-password

HIVE_CONTAINER=tier4_stu_hiveserver2
HIVE_JDBC_URL=jdbc:hive2://localhost:10000

API_PORT=5000
FLASK_DEBUG=false
CORS_ORIGINS=http://localhost:5173

# Agent (可选)
AGENT_ENABLED=false
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=
