# ClimateInsight 数据加载镜像
# 下载 NOAA GSOD → 预处理 → 写入 MySQL（完全自包含，不依赖 Hive）

FROM python:3.11-slim

WORKDIR /app

RUN pip install --no-cache-dir pymysql>=1.1 -i https://pypi.tuna.tsinghua.edu.cn/simple

# 数据下载脚本
COPY scripts/download_and_load.py /scripts/download_and_load.py
COPY scripts/etl_csv_to_mysql.py /scripts/etl_csv_to_mysql.py

# 数据目录
VOLUME /data

ENTRYPOINT ["python", "/scripts/download_and_load.py"]
